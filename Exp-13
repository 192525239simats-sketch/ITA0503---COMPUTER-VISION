import cv2
import numpy as np

# Read the image
image = cv2.imread(r"C:\Users\anilk\Pictures\WhatsApp Image 2026-07-11 at 8.07.46 PM.jpeg")

# Check if the image is loaded
if image is None:
    print("Error: Image not found!")
else:
    rows, cols, ch = image.shape

    # Define source and destination points
    pts1 = np.float32([[50, 50], [200, 50], [50, 200]])
    pts2 = np.float32([[10, 100], [200, 50], [100, 250]])

    # Compute affine transformation matrix
    matrix = cv2.getAffineTransform(pts1, pts2)

    # Apply affine transformation
    transformed_image = cv2.warpAffine(image, matrix, (cols, rows))

    # Display images
    cv2.imshow("Original Image", image)
    cv2.imshow("Affine Transformed Image", transformed_image)

    # Save the transformed image
    cv2.imwrite("affine_transformed.jpg", transformed_image)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
